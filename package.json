{
  "name": "giriraj-production-luxury",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cms": "decap-server",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:cms\"",
    "dev:sync": "npx nodemon --watch products --ext md --exec \"node scripts/sync-products.cjs\"",
    "generate:specs": "node src/scripts/generate-specs.cjs",
    "sync:house": "node src/scripts/sync-house-collection.cjs",
    "presitemap": "node scripts/sync-products.cjs",
    "build": "npm run generate:specs && npm run sync:house && npm run presitemap && vite build",
    "preview": "vite preview",
    "optimize:images": "node scripts/optimize-images.mjs",
    "security:audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "decap-cms-app": "^3.12.2",
    "decap-server": "^3.7.0",
    "gsap": "^3.13.0",
    "lenis": "^1.1.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "ffmpeg-static": "^5.3.0",
    "gray-matter": "^4.0.3",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.7"
  }
}
